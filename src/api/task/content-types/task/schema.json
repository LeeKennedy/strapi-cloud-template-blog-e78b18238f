{
  "kind": "collectionType",
  "collectionName": "tasks",
  "info": {
    "singularName": "task",
    "pluralName": "tasks",
    "displayName": "Task",
    "description": "Task content type synced from Stardog ontology"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "hasDescription": {
      "type": "text",
      "description": "has description"
    },
    "hasContent": {
      "type": "richtext",
      "description": "has content"
    },
    "slug": {
      "type": "string"
    },
    "purpose": {
      "type": "text",
      "description": "purpose"
    },
    "inputs": {
      "type": "richtext",
      "description": "inputs"
    },
    "elements": {
      "type": "richtext",
      "description": "elements"
    },
    "guidelinesAndTools": {
      "type": "richtext",
      "description": "guidelines and tools"
    },
    "stakeholders": {
      "type": "richtext",
      "description": "stakeholders"
    },
    "outputs": {
      "type": "richtext",
      "description": "outputs"
    },
    "usesTechnique": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::technique.technique",
      "description": "Relates a Task to the Technique(s) used to perform it."
    }
  }
}