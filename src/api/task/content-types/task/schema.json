{
  "kind": "collectionType",
  "collectionName": "tasks",
  "info": {
    "singularName": "task",
    "pluralName": "tasks",
    "displayName": "Task",
    "description": "Task content type synced from Stardog ontology"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "hasDescription": {
      "type": "string",
      "description": "has description"
    },
    "hasContent": {
      "type": "string",
      "description": "has content"
    },
    "slug": {
      "type": "string"
    },
    "usesTechnique": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::technique.technique",
      "description": "Relates a Task to the Technique(s) used to perform it."
    }
  }
}